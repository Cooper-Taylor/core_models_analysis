# Caches and generated artifacts
.kbcache/
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# Heuristic-variant outputs (regenerated by scripts/export_thermo_variants.py)
thermo_variants/

# Site JSON snapshots: ship static-mode files in git, ignore the FBA-only ones.
# If build_site_data.py grows a new output, decide per-file: add to this list
# to keep it out of git, or leave it alone to ship it.
site/data/baseline.json
site/data/panel.json
site/data/panel_rxnsets.json
# Guard against __pycache__ / .pyc accidentally landing under site/data/
# (the top-level __pycache__/ rule above also catches these — belt + braces).
site/data/**/__pycache__/
site/data/**/*.pyc
# Files that DO ship (committed by default — no negation needed because
# nothing above ignores them): manifest.json, reactions_panel.json,
# reactions_other.json, variants/*.json.

# Runtime logs
logs/
*.log

# Top-level data dir: symlinks to external locations (users provide their own).
# Anchored with a leading slash so it does not also match site/data/, which
# ships static-mode snapshots in git (see the explicit-deny block above).
/data/

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp

# Local Claude Code settings
.claude/

# Virtual envs
.venv/
venv/
env/
